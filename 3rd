import numpy as np
from scipy.spatial import distance
class CaseBasedReasoning:
    
    def __init__(self):
        self.case_base = []

    def add_case(self, features, label):
        self.case_base.append((np.array(features), label))

    def retrieve(self, query_features, k=1):
        query_features = np.array(query_features)
        
        similarities = [
            (case, distance.euclidean(query_features, case[0]))
            for case in self.case_base
        ]
        
        similarities.sort(key=lambda x: x[1])  # Sort by distance
        return [case[0] for case in similarities[:k]]

    def predict(self, query_features, k=1):
        nearest_cases = self.retrieve(query_features, k)
        labels = [case[1] for case in nearest_cases]
        return max(set(labels), key=labels.count)  # Majority voting

cbr = CaseBasedReasoning()
cbr.add_case([2, 3], 'A')
cbr.add_case([5, 6], 'B')
cbr.add_case([1, 2], 'A')
cbr.add_case([4, 5], 'B')

query = [3, 4]

print("Most similar cases:", cbr.retrieve(query, k=2))
print("Predicted label:", cbr.predict(query, k=2))
